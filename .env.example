# ─── Bot Credentials ────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Role IDs ────────────────────────────────────────────────────────────────
# Role given to users after successful verification
VERIFIED_ROLE_ID=1514732060856549437

# Role given to every new member when they join (before verification)
UNVERIFIED_ROLE_ID=1514733536622415972

# ─── Verification Settings ───────────────────────────────────────────────────
# How many minutes before a key expires
KEY_EXPIRY_MINUTES=10

# Max number of keys a user can generate within the rate-limit window
RATE_LIMIT_COUNT=3

# How many minutes the rate-limit window lasts
RATE_LIMIT_MINUTES=30
